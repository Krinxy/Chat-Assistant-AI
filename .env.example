# Copy this file to .env and fill in real values. Never commit .env.

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
# Minimum 64 bytes (128 hex chars) required for HS256 security
JWT_SECRET=replace-with-a-random-128-char-hex-string

# Access token lifetime — 15 minutes is the Skill-recommended max
JWT_EXPIRES_MINUTES=15

# JWT issuer + audience — must match between create and validate
JWT_ISS=aura-auth
JWT_AUD=aura-api

# Set to "jwt" in all real environments. "mock" is test-only and blocked in production.
AUTH_MODE=jwt

# ── Environment ───────────────────────────────────────────────────────────────
# Set to "production" to enable HSTS and block AUTH_MODE=mock.
ENVIRONMENT=development

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./auth.db

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slashes).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ── LLM (OpenAI-compatible gateway) ─────────────────────────────────────────────
# The model runs behind a self-/institution-hosted OpenAI-compatible endpoint
# (e.g. a Qwen deployment) — not a public cloud. Both values are read ONLY from
# this local .env: it is git-ignored (.gitignore: .env, .env.*), only this
# .env.example is committed. Never paste a real key into any tracked file.
# Access example: https://github.com/dias-digitial-assistant/llm_access
OPENAI_API_KEY=replace-with-your-gateway-api-key
OPENAI_BASE_URL=https://your-llm-gateway.example/v1
# Optional overrides — defaults live in backend/config/backend.yaml:
# LLM_MODEL=qwen3.5-think
# LLM_GUARD_MODEL=Qwen3.5-397B-A17B_No_Thinking

# ── Transcription ─────────────────────────────────────────────────────────────
# Preload Whisper on startup (slower boot) vs. lazy-load on first request.
TRANSCRIPTION_PRELOAD_ON_STARTUP=false

# Set to true only for local development without Whisper/torch installed.
# When false (default), missing dependencies surface as a proper error message.
# WHISPER_ENABLE_FAKE_FALLBACK=false

# Only used when WHISPER_ENABLE_FAKE_FALLBACK=true — returned as fake transcript text.
# WHISPER_FAKE_TRANSCRIPT_TEXT=hello world

# ── Frontend (Vite env vars) ──────────────────────────────────────────────────
# In development these are optional (defaults to localhost:8000).
# In production, point both to the Hetzner backend domain.

# REST API base URL (no trailing slash)
# VITE_API_URL=https://api.yourdomain.com

# WebSocket URL for live transcription (ws:// or wss://)
# VITE_TRANSCRIPTION_WS_URL=wss://api.yourdomain.com/ws/transcribe
