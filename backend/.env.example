# Backend Environment Variables - Copy to .env and fill in values

# MongoDB
MONGODB_URL=mongodb://admin:secret@localhost:27017/chat_assistant?authSource=admin
DATABASE_NAME=chat_assistant

# Security
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# Weather API (OpenWeatherMap)
WEATHER_API_KEY=your-openweathermap-api-key-here

# Application
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:8501","http://localhost:3000"]
