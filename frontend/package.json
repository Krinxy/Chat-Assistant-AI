    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^4.1.2",
    "esbuild": "^0.27.7",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
