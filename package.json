{
  "name": "chat-assistant-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo baseline for modular microservices",
  "workspaces": [
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint . --ext .ts,.tsx,.js --max-warnings=0 --no-error-on-unmatched-pattern",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^22.7.4",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  }
}
